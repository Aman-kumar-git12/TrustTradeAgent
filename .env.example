# 🤖 TrustTrade AI Agent — Environment Template
# Copy this file to .env and fill in your real values.
# Do NOT commit .env to version control.

# Agent Identity
AGENT_NAME=TrustTrade AI Agent
AGENT_SOURCE=python-agent
AGENT_DEFAULT_ROLE=member
AGENT_MAX_HISTORY=8

# LLM Engine (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Knowledge Base (MongoDB)
MONGODB_URI=your_mongodb_connection_string_here
DATABASE_NAME=assetdirect
KNOWLEDGE_COLLECTION_NAME=knowledges
